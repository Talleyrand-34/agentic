# agents-md-sync workflow — required environment variables
# Copy to .env and fill in real values (never commit .env)

# GitHub token with repo read + write + workflow dispatch permissions
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack webhook URL for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# n8n webhook path (set in the Webhook Trigger node)
N8N_WEBHOOK_PATH=agents-md-sync

# Library repo full name (org/repo)
LIBRARY_REPO=soulcodex/agentic

# Default branch of the library repo
LIBRARY_BRANCH=main
